CONTAINER_NAME=frieren-rvc-bridge
IMAGE_NAME=frieren-rvc-bridge:gpu-persistent
HOST_PORT=8010
KOKORO_BASE_URL=http://host.docker.internal:8880/v1
KOKORO_DEFAULT_VOICE=jf_alpha
